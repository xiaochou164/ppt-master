# ─────────────────────────────────────────────────────────────
# Image Generation Configuration / 图片生成配置
# ─────────────────────────────────────────────────────────────

# Backend: "gemini" or "openai" (default: auto-detect based on available keys)
# 后端选择："gemini" 或 "openai"（默认根据已配置的 key 自动检测）
# IMAGE_BACKEND=gemini

# API Key (required) / API 密钥（必需）
# IMAGE_API_KEY=your-api-key

# Custom API endpoint (optional, for proxy or local models)
# 自定义 API 端点（可选，用于代理服务或本地模型）
# IMAGE_BASE_URL=https://your-proxy-url.com/v1beta

# Model override (optional, each backend has its own default)
# 模型名称覆盖（可选，各后端有默认值）
# IMAGE_MODEL=gemini-3.1-flash-image-preview

# ─────────────────────────────────────────────────────────────
# Example: Gemini backend / Gemini 后端示例
# ─────────────────────────────────────────────────────────────
# IMAGE_BACKEND=gemini
# IMAGE_API_KEY=your-gemini-api-key
# IMAGE_BASE_URL=https://your-proxy-url.com/v1beta

# ─────────────────────────────────────────────────────────────
# Example: OpenAI backend / OpenAI 后端示例
# ─────────────────────────────────────────────────────────────
# IMAGE_BACKEND=openai
# IMAGE_API_KEY=sk-xxx
# IMAGE_BASE_URL=http://127.0.0.1:3000/v1
# IMAGE_MODEL=gpt-image-1

# ─────────────────────────────────────────────────────────────
# Legacy variables (still work, no need to migrate)
# 旧版变量（仍然有效，无需迁移）
# ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your-api-key
# GEMINI_BASE_URL=https://your-proxy-url.com/v1beta
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=http://127.0.0.1:3000/v1

# ─────────────────────────────────────────────────────────────
# Text / Speaker Notes Generation Configuration / 讲稿生成配置
# ─────────────────────────────────────────────────────────────

# Backend: "openai" or "gemini"
# TEXT_BACKEND=openai

# API Key (required for the selected backend)
# TEXT_API_KEY=your-api-key

# Optional custom endpoint
# TEXT_BASE_URL=http://127.0.0.1:3000/v1

# Optional model override
# TEXT_MODEL=gpt-4o-mini

# Gemini fallback example
# TEXT_BACKEND=gemini
# TEXT_API_KEY=your-gemini-api-key
# TEXT_MODEL=gemini-2.5-flash
