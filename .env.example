# ─────────────────────────────────────────────────────────────
# Image Generation Configuration / 图片生成配置
# ─────────────────────────────────────────────────────────────

# Backend: "gemini" or "openai" (default: auto-detect based on available keys)
# 后端选择："gemini" 或 "openai"（默认根据已配置的 key 自动检测）
# IMAGE_BACKEND=gemini

# API Key (required) / API 密钥（必需）
# IMAGE_API_KEY=your-api-key

# Custom API endpoint (optional, for proxy or local models)
# 自定义 API 端点（可选，用于代理服务或本地模型）
# IMAGE_BASE_URL=https://your-proxy-url.com/v1beta

# Model override (optional, each backend has its own default)
# 模型名称覆盖（可选，各后端有默认值）
# IMAGE_MODEL=gemini-3.1-flash-image-preview

# ─────────────────────────────────────────────────────────────
# Example: Gemini backend / Gemini 后端示例
# ─────────────────────────────────────────────────────────────
# IMAGE_BACKEND=gemini
# IMAGE_API_KEY=your-gemini-api-key
# IMAGE_BASE_URL=https://your-proxy-url.com/v1beta

# ─────────────────────────────────────────────────────────────
# Example: OpenAI backend / OpenAI 后端示例
# ─────────────────────────────────────────────────────────────
# IMAGE_BACKEND=openai
# IMAGE_API_KEY=sk-xxx
# IMAGE_BASE_URL=http://127.0.0.1:3000/v1
# IMAGE_MODEL=gpt-image-1

# ─────────────────────────────────────────────────────────────
# Legacy variables (still work, no need to migrate)
# 旧版变量（仍然有效，无需迁移）
# ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your-api-key
# GEMINI_BASE_URL=https://your-proxy-url.com/v1beta
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=http://127.0.0.1:3000/v1

# ─────────────────────────────────────────────────────────────
# Text / Speaker Notes Generation Configuration / 讲稿生成配置
# ─────────────────────────────────────────────────────────────

# Backend: "openai" or "gemini"
# TEXT_BACKEND=openai

# API Key (required for the selected backend)
# TEXT_API_KEY=your-api-key

# Optional custom endpoint
# TEXT_BASE_URL=http://127.0.0.1:3000/v1

# Optional model override
# TEXT_MODEL=gpt-4o-mini

# Gemini fallback example
# TEXT_BACKEND=gemini
# TEXT_API_KEY=your-gemini-api-key
# TEXT_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# Web Console Auth / Database Configuration
# ─────────────────────────────────────────────────────────────

# Enable OIDC login protection for web console
# AUTH_ENABLED=true

# Authentik OIDC issuer, client id, client secret
# Create an Authentik provider/application first, then fill in these values.
# The callback URL must match: {PPT_MASTER_PUBLIC_BASE_URL}/auth/callback
# AUTHENTIK_ISSUER_URL=https://auth.example.com/application/o/ppt-master
# AUTHENTIK_CLIENT_ID=your-client-id
# AUTHENTIK_CLIENT_SECRET=your-client-secret
# AUTHENTIK_SCOPES=openid,profile,email
# AUTHENTIK_SYNC_MODE=if_present   # strict | if_present | disabled
# AUTHENTIK_ADMIN_GROUPS=ppt-master-admins

# Session and secret encryption
# SESSION_SECRET=replace-with-a-random-secret
# APP_ENCRYPTION_KEY=replace-with-a-random-secret
# SESSION_SECURE_COOKIE=true

# Local admin bootstrap (only when AUTH_ENABLED=false)
# PPT_MASTER_LOCAL_ADMIN_EMAIL=admin@example.com
# PPT_MASTER_LOCAL_ADMIN_PASSWORD=change-me
# PPT_MASTER_LOCAL_ADMIN_NAME=Local Admin

# Database and storage
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/ppt_master
# PPT_MASTER_STORAGE_ROOT=/var/lib/ppt-master/storage

# Public callback base URL for Authentik
# PPT_MASTER_PUBLIC_BASE_URL=https://ppt.example.com

# Optional web binding
# PPT_MASTER_WEB_HOST=127.0.0.1
# PPT_MASTER_WEB_PORT=8765
